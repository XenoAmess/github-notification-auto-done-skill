# GitHub Personal Access Token.
# Supports classic PAT (ghp_*) and fine-grained PAT (github_*).
# Required scopes: notifications, repo (or equivalent for fine-grained PATs).
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Optional: only process notifications updated after this ISO 8601 timestamp.
# SINCE=2024-01-01T00:00:00Z

# Optional: concurrent API workers (default: 4).
# MAX_WORKERS=4

# Optional: comma-separated list of owner/repo to exclude.
# EXCLUDE_REPOS=owner/repo1,owner/repo2

# Optional: log file path.
# LOG_FILE=/var/log/github_notification_auto_done.log

# Optional: emit logs as JSON (default: false).
# JSON_LOGS=false

# Optional: enable DEBUG logging (default: false).
# VERBOSE=false
